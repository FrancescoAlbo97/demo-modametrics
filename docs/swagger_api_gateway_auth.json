{
    "openapi": "3.1.0",
    "info": {
        "title": "Query Pipeline — API Gateway",
        "description": "Orchestrates the full NL→MongoDB→LLM pipeline. Accepts a natural language query, converts it to a MongoDB query via query-service, executes it, and returns a report or video prompt generated by llm-service.",
        "contact": {
            "name": "Pipeline Team",
            "email": "admin@example.com"
        },
        "license": {
            "name": "MIT"
        },
        "version": "1.0.0"
    },
    "paths": {
        "/api/auth/login": {
            "post": {
                "tags": [
                    "Auth"
                ],
                "summary": "Login with username and password",
                "description": "Returns a JWT bearer token valid for the configured duration. The token is stored in MongoDB and invalidated automatically when it expires. Pass it as `Authorization: Bearer <token>` on all protected endpoints.",
                "operationId": "login_api_auth_login_post",
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/LoginRequest"
                            }
                        }
                    },
                    "required": true
                },
                "responses": {
                    "200": {
                        "description": "Successful Response",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/TokenResponse"
                                }
                            }
                        }
                    },
                    "422": {
                        "description": "Validation Error",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/HTTPValidationError"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/api/pipeline": {
            "post": {
                "tags": [
                    "Pipeline"
                ],
                "summary": "Execute end-to-end pipeline",
                "description": "Receives a natural language input, orchestrates query-service to produce a MongoDB query, executes that query, then calls llm-service to generate either a structured markdown report or a video generation prompt.",
                "operationId": "run_pipeline_api_pipeline_post",
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/PipelineRequest"
                            }
                        }
                    },
                    "required": true
                },
                "responses": {
                    "200": {
                        "description": "Successful Response",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/PipelineResponse"
                                }
                            }
                        }
                    },
                    "400": {
                        "description": "Invalid mode or request",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ErrorDetail"
                                }
                            }
                        }
                    },
                    "422": {
                        "description": "Validation error"
                    },
                    "500": {
                        "description": "Upstream service failure",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ErrorDetail"
                                }
                            }
                        }
                    },
                    "502": {
                        "description": "Downstream service error",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ErrorDetail"
                                }
                            }
                        }
                    },
                    "503": {
                        "description": "Downstream service unreachable",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ErrorDetail"
                                }
                            }
                        }
                    }
                },
                "security": [
                    {
                        "HTTPBearer": []
                    }
                ]
            }
        },
        "/api/pipeline/{pipeline_id}": {
            "get": {
                "tags": [
                    "Pipeline"
                ],
                "summary": "Retrieve pipeline result",
                "description": "Fetch a previously executed pipeline result from the MongoDB audit collection.",
                "operationId": "get_pipeline_api_pipeline__pipeline_id__get",
                "security": [
                    {
                        "HTTPBearer": []
                    }
                ],
                "parameters": [
                    {
                        "name": "pipeline_id",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "string",
                            "title": "Pipeline Id"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Successful Response",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "additionalProperties": true,
                                    "title": "Response Get Pipeline Api Pipeline  Pipeline Id  Get"
                                }
                            }
                        }
                    },
                    "404": {
                        "description": "Pipeline ID not found",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ErrorDetail"
                                }
                            }
                        }
                    },
                    "500": {
                        "description": "Database error",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ErrorDetail"
                                }
                            }
                        }
                    },
                    "422": {
                        "description": "Validation Error",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/HTTPValidationError"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/health": {
            "get": {
                "tags": [
                    "Health"
                ],
                "summary": "Health check",
                "description": "Returns the operational status of the api-gateway and all downstream services.",
                "operationId": "health_check_health_get",
                "responses": {
                    "200": {
                        "description": "Health status of all services",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/HealthResponse"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/api/ingest/posts": {
            "post": {
                "tags": [
                    "Ingest"
                ],
                "summary": "Ingest Instagram posts from JSON + zip of images",
                "description": "Accepts a multipart upload containing a JSON array of Instagram post objects and an optional zip archive of image files. Posts are upserted into instagram_posts: new posts are inserted, existing posts (matched by SHA-256 of URL) have only likesCount and commentsCount updated. Empty posts (missing url, ownerUsername, or timestamp) are filtered out. Images inside the zip are inserted into instagram_images only when their content SHA-256 is not already present. Files inside the zip that are not jpg/jpeg/png/webp are silently skipped.",
                "operationId": "ingest_posts_api_ingest_posts_post",
                "requestBody": {
                    "content": {
                        "multipart/form-data": {
                            "schema": {
                                "$ref": "#/components/schemas/Body_ingest_posts_api_ingest_posts_post"
                            }
                        }
                    },
                    "required": true
                },
                "responses": {
                    "200": {
                        "description": "Successful Response",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/IngestResponse"
                                }
                            }
                        }
                    },
                    "400": {
                        "description": "Malformed JSON or invalid zip archive",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ErrorDetail"
                                }
                            }
                        }
                    },
                    "422": {
                        "description": "Validation error"
                    },
                    "500": {
                        "description": "Database error",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ErrorDetail"
                                }
                            }
                        }
                    }
                },
                "security": [
                    {
                        "HTTPBearer": []
                    }
                ]
            }
        },
        "/api/posts/{post_id}/images": {
            "get": {
                "tags": [
                    "Posts"
                ],
                "summary": "List image metadata for a post",
                "description": "Returns metadata for all embedded images of a post (filename, index, size, content_type, content_sha). Does not return the raw image bytes — use GET /api/posts/{post_id}/images/{index} to download a specific image.",
                "operationId": "list_post_images_api_posts__post_id__images_get",
                "security": [
                    {
                        "HTTPBearer": []
                    }
                ],
                "parameters": [
                    {
                        "name": "post_id",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "string",
                            "title": "Post Id"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Successful Response",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "array",
                                    "items": {
                                        "type": "object",
                                        "additionalProperties": true
                                    },
                                    "title": "Response List Post Images Api Posts  Post Id  Images Get"
                                }
                            }
                        }
                    },
                    "404": {
                        "description": "Post not found",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ErrorDetail"
                                }
                            }
                        }
                    },
                    "500": {
                        "description": "Database error",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ErrorDetail"
                                }
                            }
                        }
                    },
                    "422": {
                        "description": "Validation Error",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/HTTPValidationError"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/api/posts/{post_id}/images/{index}": {
            "get": {
                "tags": [
                    "Posts"
                ],
                "summary": "Download a specific embedded image",
                "description": "Returns the raw image bytes with the correct Content-Type header. Use index=0 for single-image posts, index=1/2/3... for carousel images. The response can be used directly in an HTML img tag or saved to disk.",
                "operationId": "get_post_image_api_posts__post_id__images__index__get",
                "security": [
                    {
                        "HTTPBearer": []
                    }
                ],
                "parameters": [
                    {
                        "name": "post_id",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "string",
                            "title": "Post Id"
                        }
                    },
                    {
                        "name": "index",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer",
                            "title": "Index"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Raw image bytes",
                        "content": {
                            "image/jpeg": {},
                            "image/png": {},
                            "image/webp": {}
                        }
                    },
                    "404": {
                        "description": "Post or image not found",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ErrorDetail"
                                }
                            }
                        }
                    },
                    "500": {
                        "description": "Database error",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ErrorDetail"
                                }
                            }
                        }
                    },
                    "422": {
                        "description": "Validation Error",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/HTTPValidationError"
                                }
                            }
                        }
                    }
                }
            }
        }
    },
    "components": {
        "schemas": {
            "Body_ingest_posts_api_ingest_posts_post": {
                "properties": {
                    "json_file": {
                        "type": "string",
                        "format": "binary",
                        "title": "Json File",
                        "description": "JSON file containing a list of Instagram post objects"
                    },
                    "images_zip": {
                        "anyOf": [
                            {
                                "type": "string",
                                "format": "binary"
                            },
                            {
                                "type": "null"
                            }
                        ],
                        "title": "Images Zip",
                        "description": "Optional zip archive containing image files (jpg/jpeg/png/webp). Create with: zip images.zip *.jpg"
                    }
                },
                "type": "object",
                "required": [
                    "json_file"
                ],
                "title": "Body_ingest_posts_api_ingest_posts_post"
            },
            "ErrorDetail": {
                "properties": {
                    "detail": {
                        "type": "string",
                        "title": "Detail"
                    }
                },
                "type": "object",
                "required": [
                    "detail"
                ],
                "title": "ErrorDetail"
            },
            "HTTPValidationError": {
                "properties": {
                    "detail": {
                        "items": {
                            "$ref": "#/components/schemas/ValidationError"
                        },
                        "type": "array",
                        "title": "Detail"
                    }
                },
                "type": "object",
                "title": "HTTPValidationError"
            },
            "HealthResponse": {
                "properties": {
                    "status": {
                        "type": "string",
                        "enum": [
                            "ok",
                            "degraded",
                            "error"
                        ],
                        "title": "Status"
                    },
                    "services": {
                        "additionalProperties": {
                            "type": "string"
                        },
                        "type": "object",
                        "title": "Services"
                    }
                },
                "type": "object",
                "required": [
                    "status",
                    "services"
                ],
                "title": "HealthResponse",
                "examples": [
                    {
                        "services": {
                            "llm-service": "ok",
                            "mongodb": "ok",
                            "query-service": "ok"
                        },
                        "status": "ok"
                    }
                ]
            },
            "IngestResponse": {
                "properties": {
                    "ingest_id": {
                        "type": "string",
                        "title": "Ingest Id",
                        "description": "UUID identifying this ingest run"
                    },
                    "summary": {
                        "$ref": "#/components/schemas/IngestSummary",
                        "description": "Per-entity counts for this ingest run"
                    },
                    "duration_ms": {
                        "type": "integer",
                        "title": "Duration Ms",
                        "description": "Wall-clock duration of the entire ingest operation in milliseconds"
                    }
                },
                "type": "object",
                "required": [
                    "ingest_id",
                    "summary",
                    "duration_ms"
                ],
                "title": "IngestResponse",
                "examples": [
                    {
                        "duration_ms": 2150,
                        "ingest_id": "3fa85f64-5717-4562-b3fc-2c963f66afa6",
                        "summary": {
                            "images_inserted": 38,
                            "images_skipped": 2,
                            "posts_inserted": 42,
                            "posts_skipped_empty": 1,
                            "posts_unchanged": 50,
                            "posts_updated": 3
                        }
                    }
                ]
            },
            "IngestSummary": {
                "properties": {
                    "posts_inserted": {
                        "type": "integer",
                        "title": "Posts Inserted",
                        "description": "New posts inserted into instagram_posts"
                    },
                    "posts_updated": {
                        "type": "integer",
                        "title": "Posts Updated",
                        "description": "Existing posts whose likesCount or commentsCount changed and were updated"
                    },
                    "posts_unchanged": {
                        "type": "integer",
                        "title": "Posts Unchanged",
                        "description": "Existing posts whose likesCount and commentsCount were identical — no write performed"
                    },
                    "posts_skipped_empty": {
                        "type": "integer",
                        "title": "Posts Skipped Empty",
                        "description": "Posts skipped because url, ownerUsername, or timestamp was falsy"
                    },
                    "images_inserted": {
                        "type": "integer",
                        "title": "Images Inserted",
                        "description": "Images embedded into their parent post's embedded_images array"
                    },
                    "images_skipped": {
                        "type": "integer",
                        "title": "Images Skipped",
                        "description": "Images skipped because already embedded, post not found, or filename unparseable"
                    }
                },
                "type": "object",
                "required": [
                    "posts_inserted",
                    "posts_updated",
                    "posts_unchanged",
                    "posts_skipped_empty",
                    "images_inserted",
                    "images_skipped"
                ],
                "title": "IngestSummary",
                "examples": [
                    {
                        "images_inserted": 38,
                        "images_skipped": 2,
                        "posts_inserted": 42,
                        "posts_skipped_empty": 1,
                        "posts_unchanged": 50,
                        "posts_updated": 3
                    }
                ]
            },
            "LoginRequest": {
                "properties": {
                    "username": {
                        "type": "string",
                        "title": "Username"
                    },
                    "password": {
                        "type": "string",
                        "title": "Password"
                    }
                },
                "type": "object",
                "required": [
                    "username",
                    "password"
                ],
                "title": "LoginRequest",
                "examples": [
                    {
                        "password": "yourpassword",
                        "username": "admin"
                    }
                ]
            },
            "MongoQueryResult": {
                "properties": {
                    "collection": {
                        "type": "string",
                        "title": "Collection"
                    },
                    "filter": {
                        "additionalProperties": true,
                        "type": "object",
                        "title": "Filter"
                    },
                    "projection": {
                        "anyOf": [
                            {
                                "additionalProperties": true,
                                "type": "object"
                            },
                            {
                                "type": "null"
                            }
                        ],
                        "title": "Projection"
                    },
                    "sort": {
                        "anyOf": [
                            {
                                "additionalProperties": true,
                                "type": "object"
                            },
                            {
                                "type": "null"
                            }
                        ],
                        "title": "Sort"
                    },
                    "limit": {
                        "anyOf": [
                            {
                                "type": "integer"
                            },
                            {
                                "type": "null"
                            }
                        ],
                        "title": "Limit"
                    }
                },
                "type": "object",
                "required": [
                    "collection",
                    "filter"
                ],
                "title": "MongoQueryResult"
            },
            "PipelineRequest": {
                "properties": {
                    "user_input": {
                        "type": "string",
                        "title": "User Input",
                        "description": "Natural language request"
                    },
                    "mode": {
                        "type": "string",
                        "enum": [
                            "report",
                            "video"
                        ],
                        "title": "Mode",
                        "description": "Output mode"
                    },
                    "collection_hint": {
                        "anyOf": [
                            {
                                "type": "string"
                            },
                            {
                                "type": "null"
                            }
                        ],
                        "title": "Collection Hint",
                        "description": "Suggested collection name"
                    },
                    "context": {
                        "anyOf": [
                            {
                                "type": "string"
                            },
                            {
                                "type": "null"
                            }
                        ],
                        "title": "Context",
                        "description": "Extra context for LLM"
                    }
                },
                "type": "object",
                "required": [
                    "user_input",
                    "mode"
                ],
                "title": "PipelineRequest",
                "examples": [
                    {
                        "collection_hint": "instagram_posts",
                        "context": "Concentrati sui livelli di coinvolgimento",
                        "mode": "report",
                        "user_input": "Seleziona i post del 18-5-2026 con almeno 5 mi piace"
                    }
                ]
            },
            "PipelineResponse": {
                "properties": {
                    "pipeline_id": {
                        "type": "string",
                        "title": "Pipeline Id"
                    },
                    "mode": {
                        "type": "string",
                        "enum": [
                            "report",
                            "video"
                        ],
                        "title": "Mode"
                    },
                    "mongo_query": {
                        "$ref": "#/components/schemas/MongoQueryResult"
                    },
                    "raw_data": {
                        "items": {
                            "additionalProperties": true,
                            "type": "object"
                        },
                        "type": "array",
                        "title": "Raw Data"
                    },
                    "result": {
                        "type": "string",
                        "title": "Result"
                    },
                    "tokens_used": {
                        "type": "integer",
                        "title": "Tokens Used"
                    },
                    "duration_ms": {
                        "type": "integer",
                        "title": "Duration Ms"
                    }
                },
                "type": "object",
                "required": [
                    "mode",
                    "mongo_query",
                    "raw_data",
                    "result",
                    "tokens_used",
                    "duration_ms"
                ],
                "title": "PipelineResponse",
                "examples": [
                    {
                        "duration_ms": 1423,
                        "mode": "report",
                        "mongo_query": {
                            "collection": "instagram_posts",
                            "filter": {
                                "likesCount": {
                                    "$gte": 5
                                },
                                "timestamp": {
                                    "$gte": "2026-05-18T00:00:00.000Z",
                                    "$lte": "2026-05-18T23:59:59.000Z"
                                }
                            },
                            "limit": 100,
                            "sort": {
                                "likesCount": -1
                            }
                        },
                        "pipeline_id": "3fa85f64-5717-4562-b3fc-2c963f66afa6",
                        "raw_data": [
                            {
                                "caption": "Lamborghini Urus knows no compromise...",
                                "commentsCount": 0,
                                "embedded_images": [
                                    {
                                        "file_size_bytes": 84210,
                                        "filename": "CfUqpZgqnPv_1.jpg",
                                        "image_index": 1
                                    }
                                ],
                                "hashtags": [
                                    "LuxuryCarRental",
                                    "sardegna"
                                ],
                                "likesCount": 47,
                                "ownerUsername": "luxury_car_division",
                                "post_id": "CfUqpZgqnPv",
                                "timestamp": "2026-05-18T13:36:10.000Z",
                                "type": "Sidecar"
                            }
                        ],
                        "result": "## Sommario\n\nSono stati trovati 12 post pubblicati il 18 maggio 2026 con almeno 5 mi piace...",
                        "tokens_used": 512
                    }
                ]
            },
            "TokenResponse": {
                "properties": {
                    "access_token": {
                        "type": "string",
                        "title": "Access Token"
                    },
                    "token_type": {
                        "type": "string",
                        "title": "Token Type",
                        "default": "bearer"
                    },
                    "expires_in_minutes": {
                        "type": "integer",
                        "title": "Expires In Minutes"
                    }
                },
                "type": "object",
                "required": [
                    "access_token",
                    "expires_in_minutes"
                ],
                "title": "TokenResponse"
            },
            "ValidationError": {
                "properties": {
                    "loc": {
                        "items": {
                            "anyOf": [
                                {
                                    "type": "string"
                                },
                                {
                                    "type": "integer"
                                }
                            ]
                        },
                        "type": "array",
                        "title": "Location"
                    },
                    "msg": {
                        "type": "string",
                        "title": "Message"
                    },
                    "type": {
                        "type": "string",
                        "title": "Error Type"
                    }
                },
                "type": "object",
                "required": [
                    "loc",
                    "msg",
                    "type"
                ],
                "title": "ValidationError"
            }
        },
        "securitySchemes": {
            "HTTPBearer": {
                "type": "http",
                "scheme": "bearer"
            }
        }
    }
}